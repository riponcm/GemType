{
  "name": "gemtype-word",
  "version": "0.1.0",
  "private": true,
  "description": "GemType for Microsoft Word — grammar checking and AI rewrites, powered by your own Gemini API key.",
  "scripts": {
    "certs": "office-addin-dev-certs install",
    "start": "node server.js",
    "sideload": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "devDependencies": {
    "office-addin-debugging": "^6.0.0",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^2.0.0"
  }
}
